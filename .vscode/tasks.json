{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gardener: Generate ESPHome config",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\deploy.ps1",
        "-Action",
        "generate"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ESPHome: Validate generated gardener",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\deploy.ps1",
        "-Action",
        "config"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ESPHome: Compile generated gardener",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\deploy.ps1",
        "-Action",
        "compile"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ESPHome: Upload generated gardener OTA",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\deploy.ps1",
        "-Action",
        "upload",
        "-Device",
        "192.168.42.141"
      ],
      "problemMatcher": []
    },
    {
      "label": "ESPHome: Validate original reference",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "esphome",
        "config",
        "${workspaceFolder}\\esp32-s3-gardener-01.yaml"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ESPHome: Dashboard",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "esphome",
        "dashboard",
        "${workspaceFolder}"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
